# Gateway
BLOCKPILOT_GATEWAY_HOST=127.0.0.1
BLOCKPILOT_GATEWAY_PORT=8787
BLOCKPILOT_COMMAND_TIMEOUT_MS=30000
BLOCKPILOT_COMMAND_TIMEOUT_MS=15000

# Bot worker
BLOCKPILOT_BOT_ID=BlockPilot
BLOCKPILOT_GATEWAY_URL=ws://127.0.0.1:8787/worker

# Minecraft Java server
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=BlockPilot
MC_AUTH=offline
# MC_VERSION=1.21.8
BLOCKPILOT_ENTITY_SCAN_RADIUS=64
BLOCKPILOT_BLOCK_SCAN_RADIUS=64
BLOCKPILOT_DIGGABLE_BLOCK_SCAN_RADIUS=48

# Optional Mineflayer integrations. Core movement/tool/collect/pvp/auto-eat plugins are attempted automatically.
BLOCKPILOT_ARMOR_MANAGER=false
BLOCKPILOT_TPS_PLUGIN=false
BLOCKPILOT_HAWKEYE=false
BLOCKPILOT_DASHBOARD=false
BLOCKPILOT_VIEWER=false
BLOCKPILOT_VIEWER_PORT=3007
BLOCKPILOT_VIEWER_FIRST_PERSON=false
BLOCKPILOT_WEB_INVENTORY=false
BLOCKPILOT_WEB_INVENTORY_PORT=3008

# Agent runtime
BLOCKPILOT_GATEWAY_HTTP=http://127.0.0.1:8787
BLOCKPILOT_AGENT_PLANNER=llm
BLOCKPILOT_AGENT_PREFIX=!bp
BLOCKPILOT_AGENT_ALIASES=bp,helper
BLOCKPILOT_AGENT_TICK_MS=2000
BLOCKPILOT_AGENT_ALLOWED_ACTIONS=chat,follow_player,go_to_position,dig_nearest_block,place_block,craft_item,build_preset,use_nearest_block,inspect_nearest_container,deposit_item_to_container,withdraw_item_from_container,collect_nearest_item,drop_item,attack_nearest_entity,stop,report_position,world_snapshot,eat_food,retreat_from_threat
# Set to 0 to disable duplicate reply suppression while debugging.
BLOCKPILOT_RESPONSE_DEDUP_MS=30000
# Detailed decision logs: off, console, file, both, or true for console.
BLOCKPILOT_AGENT_DECISION_LOG=off
BLOCKPILOT_AGENT_DECISION_LOG_FILE=.blockpilot/logs/BlockPilot-decisions.jsonl

# Agent memory and autonomy
BLOCKPILOT_MEMORY_FILE=.blockpilot/memory/BlockPilot.json
BLOCKPILOT_AUTONOMY=false
BLOCKPILOT_AUTONOMY_MODE=companion
BLOCKPILOT_AUTONOMY_INTERVAL_MS=60000
BLOCKPILOT_AUTONOMY_CHAT=true
BLOCKPILOT_AUTONOMY_REQUIRE_RECENT_CHAT=true
BLOCKPILOT_AUTONOMY_RECENT_CHAT_WINDOW_MS=180000
BLOCKPILOT_AUTONOMY_STARTUP_GRACE_MS=120000

# Safety reflex
BLOCKPILOT_SAFETY_REFLEX=true
BLOCKPILOT_SAFETY_COOLDOWN_MS=5000
BLOCKPILOT_SAFETY_NOTICE=false
BLOCKPILOT_SAFETY_NOTICE_COOLDOWN_MS=15000

# LLM provider
BLOCKPILOT_LLM_API_KEY=replace-with-your-api-key
BLOCKPILOT_LLM_BASE_URL=https://api.openai.com/v1
BLOCKPILOT_LLM_MODEL=replace-with-your-model
BLOCKPILOT_LLM_TEMPERATURE=0.4
# Increase this if the provider/model often takes longer than 30s.
BLOCKPILOT_LLM_TIMEOUT_MS=30000
