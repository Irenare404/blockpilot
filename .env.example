# Gateway
BLOCKPILOT_GATEWAY_HOST=127.0.0.1
BLOCKPILOT_GATEWAY_PORT=8787
BLOCKPILOT_COMMAND_TIMEOUT_MS=15000

# Bot worker
BLOCKPILOT_BOT_ID=BlockPilot
BLOCKPILOT_GATEWAY_URL=ws://127.0.0.1:8787/worker

# Minecraft Java server
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=BlockPilot
MC_AUTH=offline
# MC_VERSION=1.21.8

# Agent runtime
BLOCKPILOT_GATEWAY_HTTP=http://127.0.0.1:8787
BLOCKPILOT_AGENT_PLANNER=llm
BLOCKPILOT_AGENT_PREFIX=!bp
BLOCKPILOT_AGENT_ALIASES=bp,helper
BLOCKPILOT_AGENT_TICK_MS=2000
BLOCKPILOT_AGENT_ALLOWED_ACTIONS=chat,follow_player,go_to_position,dig_nearest_block,place_block,use_nearest_block,inspect_nearest_container,collect_nearest_item,stop,report_position,world_snapshot,eat_food,retreat_from_threat
BLOCKPILOT_RESPONSE_DEDUP_MS=30000
BLOCKPILOT_AGENT_DECISION_LOG=off
BLOCKPILOT_AGENT_DECISION_LOG_FILE=.blockpilot/logs/BlockPilot-decisions.jsonl

# Agent memory and autonomy
BLOCKPILOT_MEMORY_FILE=.blockpilot/memory/BlockPilot.json
BLOCKPILOT_AUTONOMY=false
BLOCKPILOT_AUTONOMY_MODE=companion
BLOCKPILOT_AUTONOMY_INTERVAL_MS=60000
BLOCKPILOT_AUTONOMY_CHAT=true

# Safety reflex
BLOCKPILOT_SAFETY_REFLEX=true
BLOCKPILOT_SAFETY_COOLDOWN_MS=5000
BLOCKPILOT_SAFETY_NOTICE=false
BLOCKPILOT_SAFETY_NOTICE_COOLDOWN_MS=15000

# LLM provider
BLOCKPILOT_LLM_API_KEY=replace-with-your-api-key
BLOCKPILOT_LLM_BASE_URL=https://api.openai.com/v1
BLOCKPILOT_LLM_MODEL=replace-with-your-model
BLOCKPILOT_LLM_TEMPERATURE=0.4
BLOCKPILOT_LLM_TIMEOUT_MS=30000
